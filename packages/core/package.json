{
  "name": "@ecru/core",
  "version": "0.0.0",
  "description": "Ecru core components — atomic, Tailwind v4, copy-paste friendly.",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./src/styles/index.css",
    "./components/*": {
      "types": "./src/components/*.tsx",
      "import": "./src/components/*.tsx"
    }
  },
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ecru/tokens": "workspace:*",
    "@ecru/utils": "workspace:*",
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@ecru/tsconfig": "workspace:*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
